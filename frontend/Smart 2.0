                  <span class="input-group-text"><i class="fas fa-search"></i></span>
                  <input type="text" class="form-control" id="search-inquiries" placeholder="Search inquiries...">
                </div>
              </div>
              <div class="col-lg-4 text-lg-end">
                <div class="btn-group">
                  <button type="button" class="btn btn-outline-primary">Export</button>
                  <button type="button" class="btn btn-outline-primary">Print</button>
                  <button type="button" class="btn btn-outline-primary">Filter</button>
                </div>
              </div>
            </div>
